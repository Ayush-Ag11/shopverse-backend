# EditorConfig helps maintain consistent formatting across editors and IDEs.
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.java]
indent_style = space
indent_size = 4
continuation_indent_size = 4
max_line_length = 120

[*.{yml,yaml,json,xml}]
indent_style = space
indent_size = 2

[*.properties]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false
max_line_length = off

[*.{sh,bash}]
end_of_line = lf
indent_style = space
indent_size = 2

[*.bat]
end_of_line = crlf
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab
